{
  "name": "geopanel-workspace",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "frontend:dev": "bun --cwd frontend run dev",
    "frontend:build": "bun --cwd frontend run build",
    "frontend:check": "bun --cwd frontend run check",
    "frontend:format": "bun --cwd frontend run format",
    "backend:dev": "cd backend && go run ./cmd/api",
    "backend:build": "cd backend && go build ./cmd/api",
    "db:test:up": "docker compose -f docker-compose.postgis-test.yml up -d",
    "db:test:down": "docker compose -f docker-compose.postgis-test.yml down",
    "db:test:reset": "docker compose -f docker-compose.postgis-test.yml down -v && docker compose -f docker-compose.postgis-test.yml up -d",
    "db:test:logs": "docker compose -f docker-compose.postgis-test.yml logs -f postgis-test"
  }
}
